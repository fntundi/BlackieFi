# ---- Build Stage: Build the React Client ----
FROM node:20-slim AS client-builder
# Install pnpm globally
RUN npm install -g pnpm
WORKDIR /app
# Copy all source files for monorepo context
COPY . .
# Install all dependencies for the client workspace
RUN pnpm install --filter client
# Build the static assets (HTML, CSS, JS)
RUN pnpm --filter client build

# ---- Production Stage: Configure and run Nginx ----
FROM nginx:1.25-alpine AS production
# Remove the default Nginx welcome page
RUN rm /etc/nginx/conf.d/default.conf

# Copy our custom Nginx configuration
# (We will create this nginx.conf file in the next step)
COPY nginx/nginx.conf /etc/nginx/conf.d/default.conf

# Copy the built static files from the client-builder stage
COPY --from=client-builder /app/client/dist /usr/share/nginx/html

EXPOSE 80
# The base Nginx image handles starting the server automatically